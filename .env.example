# Copy to `.env.local` and fill in one provider (or both for fallback).

# Optional: `gemini` (default) or `openai` — tries the other if the first fails.
# AI_PROVIDER=gemini

# --- Google Gemini (recommended if set first when AI_PROVIDER is unset)
GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (used if Gemini fails, or first when AI_PROVIDER=openai)
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
