# Copy to `.env.local`.
# Free mode works even without API keys when ALLOW_DEMO_FALLBACK is enabled.

# Optional: `gemini` (default) or `openai` — tries the other if the first fails.
# AI_PROVIDER=gemini

# --- Google Gemini (optional)
# GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI (optional, usually paid)
# OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: set false to disable built-in local JSX fallback.
# ALLOW_DEMO_FALLBACK=true
